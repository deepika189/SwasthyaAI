# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Model Paths
MODEL_PATH=models/best_model.joblib
FEATURE_COLUMNS_PATH=models/feature_columns.joblib
LABEL_ENCODER_PATH=models/label_encoder.joblib

# Dataset Path
DATASET_PATH=data/disease_symptom_dataset.csv

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# UI Configuration
UI_PORT=8501

# Optional S3 Logging
S3_BUCKET_NAME=
S3_LOG_PREFIX=swasthyaai-logs/

# Logging
LOG_LEVEL=INFO

# RAG System Configuration
# Enable/disable the Ayurvedic RAG remedies feature
RAG_ENABLED=true

# Path to the Ayurvedic remedies PDF file
RAG_PDF_PATH=data/The complete book of Ayurvedic home remedies.pdf

# Path to store/load the FAISS vector index (will be created if doesn't exist)
RAG_INDEX_PATH=data/faiss_index

# Text chunking parameters for PDF processing
# Chunk size: number of characters per chunk (default: 1000)
RAG_CHUNK_SIZE=1000
# Chunk overlap: number of overlapping characters between chunks (default: 200)
RAG_CHUNK_OVERLAP=200

# Number of most relevant chunks to retrieve for context (default: 3)
RAG_TOP_K=3

# Bedrock model IDs for RAG components
# Embeddings model for vector generation
# Options: amazon.titan-embed-text-v2:0 (recommended), amazon.titan-embed-text-v1
RAG_EMBEDDINGS_MODEL=amazon.titan-embed-text-v2:0
# LLM model for remedy generation (default: anthropic.claude-3-haiku-20240307-v1:0)
RAG_LLM_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# Maximum number of retries for LLM API calls (default: 2)
RAG_MAX_RETRIES=2
